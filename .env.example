# unifictl connection & secrets — copy to .env and fill in. Never commit .env.
UNIFI_BASE_URL=https://192.168.1.1
UNIFI_API_KEY=

# Optional connection settings:
# UNIFI_SITE=default              # private-API site is the internal reference, not the v1 UUID
# UNIFI_CA_CERT=/path/to/controller-ca.pem
# UNIFI_INSECURE_TLS=false        # last-resort TLS bypass
# UNIFI_TIMEOUT_MS=30000
